---
import Header from '../components/site/Header.astro';
import Footer from '../components/site/Footer.astro';
import '../styles/global.css';

type Props = {
	title?: string;
	description?: string;
	ogImage?: string;
	ogType?: 'website' | 'article';
	robots?: string;
	jsonLd?: Record<string, any> | Record<string, any>[];
	articleDate?: string;
	articleModified?: string;
};

const {
	title = 'Winner IT — รับซื้อโน๊ตบุ๊ค คอม IT มือสอง',
	description = 'Winner IT รับซื้อโน๊ตบุ๊ค คอมพิวเตอร์ อุปกรณ์ IT มือสอง ราคาดี บริการรวดเร็ว ติดต่อ Line @WEBUY',
	ogImage,
	ogType = 'website',
	robots,
	jsonLd,
	articleDate,
	articleModified,
} = Astro.props as Props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://winnerit.in.th';
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const defaultOgImage = `${siteUrl}/og-default.png`;
const ogImageUrl = ogImage ?? defaultOgImage;

const orgSchema = {
	'@type': 'Organization',
	'@id': `${siteUrl}/#organization`,
	name: 'Winner IT',
	legalName: 'บริษัท อำพล เทรดดิ้ง จำกัด',
	url: siteUrl,
	logo: {
		'@type': 'ImageObject',
		url: `${siteUrl}/favicon.svg`,
	},
	contactPoint: {
		'@type': 'ContactPoint',
		contactType: 'customer service',
		telephone: '+66-64-257-9353',
		email: 'amphontrading@gmail.com',
		availableLanguage: 'Thai',
	},
	sameAs: [
		'https://line.me/R/ti/p/@webuy',
		'https://amphontd.com/',
		'https://webuy.in.th/',
	],
};

const localBusinessSchema = {
	'@type': 'LocalBusiness',
	'@id': `${siteUrl}/#localbusiness`,
	name: 'Winner IT (ร้านอำพล เทรดดิ้ง)',
	alternateName: 'AMPHON TRADING',
	image: `${siteUrl}/og-default.png`,
	url: siteUrl,
	telephone: '+66-64-257-9353',
	email: 'amphontrading@gmail.com',
	priceRange: '฿',
	address: {
		'@type': 'PostalAddress',
		streetAddress: '740/8 ถนนชยางกูร',
		addressLocality: 'เมืองอุบลราชธานี',
		addressRegion: 'อุบลราชธานี',
		postalCode: '34000',
		addressCountry: 'TH',
	},
	geo: {
		'@type': 'GeoCoordinates',
		latitude: 15.2448,
		longitude: 104.8473,
	},
	openingHoursSpecification: [
		{
			'@type': 'OpeningHoursSpecification',
			dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],
			opens: '09:00',
			closes: '18:00',
		},
	],
	areaServed: {
		'@type': 'Country',
		name: 'Thailand',
	},
	parentOrganization: { '@id': `${siteUrl}/#organization` },
};

const websiteSchema = {
	'@type': 'WebSite',
	'@id': `${siteUrl}/#website`,
	name: 'Winner IT',
	url: siteUrl,
	publisher: { '@id': `${siteUrl}/#organization` },
	inLanguage: 'th-TH',
};

const baseJsonLd = {
	'@context': 'https://schema.org',
	'@graph': [
		orgSchema,
		localBusinessSchema,
		websiteSchema,
		...(Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : []),
	],
};
---

<!doctype html>
<html lang="th">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="canonical" href={canonicalUrl.toString()} />
		{robots && <meta name="robots" content={robots} />}
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="theme-color" content="#F97316" />
		<meta name="geo.region" content="TH-34" />
		<meta name="geo.placename" content="อุบลราชธานี" />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

		<meta property="og:type" content={ogType} />
		<meta property="og:url" content={canonicalUrl.toString()} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:locale" content="th_TH" />
		<meta property="og:site_name" content="Winner IT" />
		{articleDate && <meta property="article:published_time" content={articleDate} />}
		{articleModified && <meta property="article:modified_time" content={articleModified} />}

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />

		<link rel="alternate" type="application/rss+xml" title="Winner IT RSS" href="/rss.xml" />

		<script type="application/ld+json" set:html={JSON.stringify(baseJsonLd)} />
	</head>
	<body>
		<Header />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>
