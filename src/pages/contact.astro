---
import Layout from '../layouts/Layout.astro';
---

<Layout title="ติดต่อ — Winner IT" description="ติดต่อ Winner IT เพื่อประเมินราคาอุปกรณ์ IT มือสอง แอดไลน์ @WEBUY หรือส่งอีเมลได้ทันที">
	<section class="hero">
		<div class="hero-bg"></div>
		<div class="container hero-inner">
			<span class="pill">ติดต่อเรา</span>
			<h1>ติดต่อทีมงาน Winner IT</h1>
			<p class="lead">
				แอดไลน์ @WEBUY ส่งรูปพร้อมรายละเอียดอุปกรณ์ หรือกรอกฟอร์มด้านล่างเพื่อให้ทีมงานติดต่อกลับ
			</p>
		</div>
	</section>

	<section class="body-sec">
		<div class="container">
			<!-- Quick Contact Cards -->
			<div class="quick-grid">
				<a href="https://line.me/R/ti/p/@webuy" target="_blank" rel="noopener" class="q-card q-line">
					<svg width="28" height="28" viewBox="0 0 24 24" fill="#06C755"><path d="M12 2C6.48 2 2 5.83 2 10.44c0 4.17 3.7 7.66 8.69 8.32.34.07.8.23.91.52.1.27.07.68.03.95l-.15.88c-.04.25-.2.99.87.54s5.78-3.4 7.88-5.82C22.08 13.79 22 12.16 22 10.44 22 5.83 17.52 2 12 2z"/></svg>
					<strong>Line @WEBUY</strong>
					<span>วิธีที่เร็วที่สุดในการติดต่อเรา</span>
				</a>
				<a href="mailto:amphontrading@gmail.com" class="q-card q-email">
					<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="3"/><path d="M22 4l-10 8L2 4"/></svg>
					<strong>amphontrading@gmail.com</strong>
					<span>ส่งอีเมลถึงทีมงาน</span>
				</a>
			</div>

			<div class="g2">
				<div class="box">
					<h2>แบบฟอร์มติดต่อ</h2>
					<form class="form" action="mailto:amphontrading@gmail.com" method="post" enctype="text/plain">
						<label>
							<span class="lb">ชื่อ</span>
							<input name="name" required class="inp" placeholder="ชื่อ-นามสกุล" />
						</label>
						<label>
							<span class="lb">อีเมล</span>
							<input type="email" name="email" required class="inp" placeholder="email@example.com" />
						</label>
						<label>
							<span class="lb">รายละเอียด</span>
							<textarea name="message" rows={6} required class="inp ta" placeholder="อธิบายรายละเอียดอุปกรณ์ หรือสิ่งที่ต้องการติดต่อ..."></textarea>
						</label>
						<button class="btn btn-primary btn-big" type="submit">
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
							ส่งข้อความ
						</button>
					</form>
				</div>

				<div class="box">
					<h2>แผนที่</h2>
					<div class="map">
						<iframe title="Winner IT location map" loading="lazy" referrerpolicy="no-referrer-when-downgrade" src="https://www.google.com/maps?q=Bangkok&output=embed"></iframe>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>

<style>
	.hero {
		position: relative;
		padding: 80px 0 64px;
		text-align: center;
		overflow: hidden;
	}
	.hero-bg {
		position: absolute;
		inset: 0;
		background: linear-gradient(168deg, #fff7ed 0%, #fffbf5 30%, #fff 60%);
		z-index: 0;
	}
	.hero-inner {
		position: relative;
		z-index: 1;
		animation: fadeUp .6s var(--ease-out) both;
	}
	@keyframes fadeUp {
		from { opacity: 0; transform: translateY(20px); }
		to { opacity: 1; transform: translateY(0); }
	}
	.hero h1 {
		font-size: 42px;
		margin: 16px 0 0;
		letter-spacing: -.03em;
	}
	.lead {
		margin: 16px auto 0;
		font-size: 17px;
		color: var(--muted);
		line-height: 1.75;
		max-width: 600px;
	}

	.body-sec {
		padding: 48px 0 80px;
	}

	.quick-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 20px;
		margin-bottom: 28px;
	}
	.q-card {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 8px;
		padding: 28px 24px;
		border-radius: 16px;
		background: #fff;
		border: 1.5px solid var(--border);
		text-decoration: none;
		color: var(--text);
		box-shadow: var(--shadow-card);
		transition: all .3s var(--ease-out);
		text-align: center;
	}
	.q-card:hover {
		transform: translateY(-3px);
		box-shadow: var(--shadow-hover);
	}
	.q-line:hover { border-color: #06C755; }
	.q-email:hover { border-color: var(--accent); }
	.q-card strong {
		font-size: 16px;
		font-weight: 700;
	}
	.q-card span {
		font-size: 13px;
		color: var(--muted);
	}

	.g2 {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 28px;
	}
	.box {
		background: #fff;
		border: 1px solid var(--border);
		border-radius: 20px;
		padding: 36px;
		box-shadow: var(--shadow-card);
	}
	.box h2 {
		margin: 0 0 24px;
		font-size: 22px;
	}

	.form {
		display: grid;
		gap: 18px;
	}
	label {
		display: grid;
		gap: 6px;
	}
	.lb {
		font-weight: 600;
		font-size: 14px;
		color: var(--text);
	}
	.inp {
		padding: 13px 16px;
		border-radius: 12px;
		border: 1.5px solid var(--border);
		background: var(--bg-alt);
		color: var(--text);
		font-size: 15px;
		font-family: inherit;
		transition: all .25s var(--ease-out);
	}
	.inp::placeholder {
		color: var(--muted);
		opacity: .5;
	}
	.inp:focus {
		outline: none;
		border-color: var(--accent);
		background: #fff;
		box-shadow: 0 0 0 4px rgba(249,115,22,.08);
	}
	.ta { resize: vertical; min-height: 120px; }

	.map {
		border-radius: 16px;
		overflow: hidden;
		border: 1px solid var(--border);
		box-shadow: var(--shadow-xs);
		height: 100%;
		min-height: 300px;
	}
	.map iframe {
		border: 0;
		width: 100%;
		height: 100%;
		min-height: 300px;
		display: block;
	}

	@media (max-width: 900px) {
		.hero h1 { font-size: 34px; }
		.quick-grid { grid-template-columns: 1fr; }
		.g2 { grid-template-columns: 1fr; }
	}
</style>
