---
import Layout from '../../../layouts/Layout.astro';
import { getAllPosts, type WPPost } from '../../../lib/wp';
import PostCard from '../../../components/blog/PostCard.astro';

export async function getStaticPaths() {
	const pageSize = 12;
	const postsAll = (await getAllPosts()).sort((a: WPPost, b: WPPost) => (a.date < b.date ? 1 : -1));
	const totalPages = Math.max(1, Math.ceil(postsAll.length / pageSize));
	return Array.from({ length: totalPages - 1 }, (_, i) => {
		const page = i + 2;
		return {
			params: { page: String(page) },
			props: {
				page,
				totalPages,
				posts: postsAll.slice((page - 1) * pageSize, page * pageSize),
			},
		};
	});
}

const { page, totalPages, posts } = Astro.props as { page: number; totalPages: number; posts: WPPost[] };

const delta = 2;
const pagRange: (number | string)[] = [];
for (let i = 1; i <= totalPages; i++) {
	if (i === 1 || i === totalPages || (i >= page - delta && i <= page + delta)) {
		pagRange.push(i);
	} else if (pagRange[pagRange.length - 1] !== '...') {
		pagRange.push('...');
	}
}
---

<Layout title={`บทความ หน้า ${page} จาก ${totalPages} — Winner IT`} description={`อ่านบทความเกี่ยวกับการรับซื้ออุปกรณ์ IT มือสอง หน้า ${page} จาก ${totalPages} — เทคนิค ข่าวสาร ความรู้จาก Winner IT`}>
	<section class="hero">
		<div class="hero-bg"></div>
		<div class="container hero-inner">
			<span class="pill">บทความ</span>
			<h1>บทความล่าสุด</h1>
			<p class="lead">หน้า {page} จาก {totalPages}</p>
		</div>
	</section>

	<section class="container list">
		<div class="grid-3">
			{posts.map((post) => <PostCard post={post} />)}
		</div>
	</section>

	{totalPages > 1 && (
		<section class="container pag">
			{page > 1 && (
				<a class="pag-btn pag-arrow" href={page === 2 ? '/articles' : `/articles/page/${page - 1}`} aria-label="หน้าก่อนหน้า">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
				</a>
			)}
			{pagRange.map((item) =>
				item === '...'
					? <span class="pag-dots">&hellip;</span>
					: <a class:list={['pag-btn', { active: item === page }]} href={item === 1 ? '/articles' : `/articles/page/${item}`} aria-current={item === page ? 'page' : undefined}>{item}</a>
			)}
			{page < totalPages && (
				<a class="pag-btn pag-arrow" href={`/articles/page/${page + 1}`} aria-label="หน้าถัดไป">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
				</a>
			)}
		</section>
	)}
</Layout>

<style>
	.hero {
		position: relative;
		padding: 72px 0 52px;
		text-align: center;
		overflow: hidden;
	}
	.hero-bg {
		position: absolute;
		inset: 0;
		background: linear-gradient(168deg, #fff7ed 0%, #fffbf5 30%, #fff 60%);
		z-index: 0;
	}
	.hero-inner {
		position: relative;
		z-index: 1;
	}
	.hero h1 {
		font-size: 38px;
		margin: 14px 0 0;
		letter-spacing: -.03em;
	}
	.lead {
		margin: 10px 0 0;
		color: var(--muted);
		font-size: 16px;
	}
	.list { padding: 48px 0; }
	.pag {
		padding: 0 0 64px;
		display: flex;
		gap: 8px;
		justify-content: center;
		flex-wrap: wrap;
	}
	.pag-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 42px;
		height: 42px;
		border-radius: 10px;
		border: 1.5px solid var(--border);
		background: #fff;
		color: var(--text);
		font-size: 15px;
		font-weight: 600;
		text-decoration: none;
		transition: all .25s var(--ease-out);
	}
	.pag-btn:hover {
		border-color: var(--accent);
		color: var(--accent);
		background: var(--accent-light);
		transform: translateY(-2px);
	}
	.pag-btn.active {
		border-color: var(--accent);
		background: linear-gradient(135deg, var(--accent), var(--accent-hover));
		color: #fff;
		box-shadow: 0 2px 8px rgba(249,115,22,.25);
		pointer-events: none;
	}
	.pag-arrow {
		width: 42px;
		color: var(--muted);
	}
	.pag-arrow:hover { color: var(--accent); }
	.pag-dots {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 32px;
		height: 42px;
		color: var(--muted);
		font-size: 16px;
		letter-spacing: .1em;
	}
</style>
