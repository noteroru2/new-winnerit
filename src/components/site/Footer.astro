<style>
	.footer { margin-top: 0; }

	.ft-cta {
		padding: 48px 0;
		background: var(--bg-alt, #faf7f4);
	}
	.fc-inner {
		position: relative;
		background: linear-gradient(135deg, #1a1207 0%, #2d2418 50%, #1a1207 100%);
		border-radius: 24px;
		padding: 48px;
		overflow: hidden;
	}
	.fc-glow {
		position: absolute;
		top: -80px;
		right: -60px;
		width: 280px;
		height: 280px;
		border-radius: 50%;
		background: radial-gradient(circle, rgba(249,115,22,.2) 0%, transparent 70%);
		pointer-events: none;
	}
	.fc-glow::after {
		content: '';
		position: absolute;
		bottom: -120px;
		left: -40px;
		width: 200px;
		height: 200px;
		border-radius: 50%;
		background: radial-gradient(circle, rgba(249,115,22,.1) 0%, transparent 70%);
	}
	.fc-content {
		position: relative;
		z-index: 1;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 32px;
		flex-wrap: wrap;
	}
	.fc-badge {
		display: inline-block;
		padding: 5px 14px;
		border-radius: 100px;
		background: rgba(249,115,22,.15);
		color: #F97316;
		font-size: 12px;
		font-weight: 700;
		letter-spacing: .04em;
		margin-bottom: 12px;
	}
	.fc h3 {
		margin: 0;
		font-size: 24px;
		color: #fff;
		font-weight: 700;
		letter-spacing: -.01em;
	}
	.fc p {
		margin: 8px 0 0;
		font-size: 15px;
		color: rgba(255,255,255,.55);
	}
	.fc-btn {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		padding: 15px 30px;
		border-radius: 14px;
		background: #fff;
		color: var(--text, #1a1207);
		font-weight: 700;
		font-size: 16px;
		text-decoration: none;
		white-space: nowrap;
		box-shadow: 0 4px 20px rgba(0,0,0,.15);
		transition: all .3s var(--ease-out, cubic-bezier(0.16,1,0.3,1));
	}
	.fc-btn:hover {
		background: var(--accent-light, #fff7ed);
		color: var(--accent-hover, #ea580c);
		transform: translateY(-3px);
		box-shadow: 0 8px 32px rgba(0,0,0,.2);
	}

	.ft-main {
		background: var(--bg-alt, #faf7f4);
		padding: 56px 0 48px;
		border-top: 1px solid var(--border, #ebe4db);
	}
	.ft-grid {
		display: grid;
		grid-template-columns: 1.5fr 1fr 1fr 1fr 1.2fr;
		gap: 36px;
	}
	.ft-logo {
		display: flex;
		align-items: center;
		gap: 10px;
		text-decoration: none;
		color: var(--text);
		margin-bottom: 16px;
	}
	.ft-mark {
		width: 34px;
		height: 34px;
		border-radius: 10px;
		background: linear-gradient(135deg, #F97316, #ea580c);
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		box-shadow: 0 2px 8px rgba(249,115,22,.2);
		color: #fff;
		font-weight: 900;
		font-size: 18px;
		line-height: 1;
	}
	.ft-name {
		font-weight: 800;
		font-size: 17px;
	}
	.ft-desc {
		font-size: 14px;
		color: var(--muted);
		line-height: 1.75;
	}
	.ft-company {
		font-size: 12px;
		color: var(--muted);
		opacity: .7;
		margin-top: 8px;
		line-height: 1.6;
	}

	.ft-col h4 {
		font-size: 13px;
		font-weight: 700;
		margin-bottom: 18px;
		color: var(--text);
		text-transform: uppercase;
		letter-spacing: .06em;
	}
	.ft-col ul {
		list-style: none;
		display: grid;
		gap: 12px;
	}
	.ft-col a {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		color: var(--muted);
		font-size: 14px;
		text-decoration: none;
		transition: all .2s;
	}
	.ft-col a:hover {
		color: var(--accent-hover);
		transform: translateX(3px);
	}

	.contact-line {
		color: #06C755 !important;
		font-weight: 700;
	}
	.contact-line:hover {
		color: #059e44 !important;
	}

	.ft-bottom {
		border-top: 1px solid var(--border);
		background: var(--bg, #fff);
	}
	.ft-bot {
		padding: 20px 0;
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-size: 13px;
		color: var(--muted);
		flex-wrap: wrap;
		gap: 8px;
	}
	.ft-links {
		display: flex;
		gap: 8px;
		align-items: center;
	}
	.ft-sep { opacity: .4; }
	.ft-links a {
		color: var(--muted);
		text-decoration: none;
		transition: color .2s;
	}
	.ft-links a:hover {
		color: var(--accent-hover);
	}

	@media (max-width: 900px) {
		.ft-grid {
			grid-template-columns: 1fr 1fr;
			gap: 32px;
		}
		.ft-brand { grid-column: 1 / -1; }
		.fc-inner { padding: 36px 28px; }
		.fc-content {
			flex-direction: column;
			text-align: center;
			align-items: center;
		}
	}
	@media (max-width: 480px) {
		.ft-grid { grid-template-columns: 1fr; }
	}
</style>
